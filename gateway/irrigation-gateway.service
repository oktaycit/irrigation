[Unit]
Description=Irrigation STM32 Gateway
After=default.target

[Service]
Type=simple
WorkingDirectory=%h/irrigation-gateway
ExecStart=/usr/bin/python3 %h/irrigation-gateway/app.py --host 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=3
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=default.target
